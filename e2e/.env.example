# =============================================================================
# Required — fill these in before running any script
# =============================================================================

# TODO: replace with your test wallet private key (never use a funded mainnet key)
PRIVATE_KEY_SEPOLIA=0x01234...
PRIVATE_KEY_BASE_SEPOLIA=0x01234...

# =============================================================================
# EVM ↔ EVM
# =============================================================================

# Off-chain quotes — pre-deployed demo contracts (use as-is, or deploy your own)
HELLO_WORMHOLE_SEPOLIA=0x8f6E15d9A4d0abCe4814c7d86D5B741A91bDCC04
HELLO_WORMHOLE_BASE_SEPOLIA=0xdF781F7473a1A7C20C1e5fC5f427Fa712dafB698

# On-chain quotes — TODO: deploy with forge script/HelloWormholeOnChainQuote.s.sol, then fill in
HELLO_WORMHOLE_OC_SEPOLIA=0x...
HELLO_WORMHOLE_OC_BASE_SEPOLIA=0x...

# Wormhole-operated on-chain quoter — do not change
QUOTER_ADDRESS=0x5241c9276698439fef2780dbab76fec90b633fbd

# Optional: override default RPC endpoints
# SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
# BASE_SEPOLIA_RPC_URL=https://base-sepolia-rpc.publicnode.com

# =============================================================================
# EVM ↔ Solana (Cross-VM) — additional setup required
# Wormhole chain IDs reference: https://wormhole.com/docs/products/reference/chain-ids/
#   Solana = 1, Sepolia = 10002, Ethereum mainnet = 2, etc.
# =============================================================================

# EVM contract address — this example targets Sepolia (testnet).
# For mainnet: deploy to Ethereum mainnet, set SEPOLIA_RPC_URL to a mainnet RPC,
# and update CHAIN_ID_SEPOLIA in sendToSolana.ts to the appropriate Wormhole chain ID.
# TODO: deploy with: forge script script/HelloWormhole.s.sol --rpc-url $SEPOLIA_RPC_URL --broadcast
HELLO_WORMHOLE_SEPOLIA_CROSSVM=0x...

# Solana peer addresses — see script/SetupSolanaPeer.s.sol for how to derive these
# TODO: update if you deployed your own Solana program (defaults point to the demo program)
SOLANA_PROGRAM_ID_BYTES32=0x62cf7e5a219d24a831e51b2c2417fa898920b930fd1c6947f3a4fc8feec1020f
SOLANA_EMITTER_PDA_BYTES32=0x58235d29729e44920df367836a92ab77fcee36b7a27b03304cd699f5eb0efae5

# =============================================================================
# Note: the following are provided automatically by the Wormhole SDK
#   - Wormhole chain IDs
#   - CoreBridge addresses
#   - Executor addresses
#   - Default RPC URLs (overridable above)
# =============================================================================
