# Private keys (DO NOT COMMIT REAL KEYS - use a test wallet!)
PRIVATE_KEY_SEPOLIA=0x01234...
PRIVATE_KEY_BASE_SEPOLIA=0x01234...

# RPC URLs (Optional - SDK has defaults, but you can override)
# SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
# BASE_SEPOLIA_RPC_URL=https://base-sepolia-rpc.publicnode.com

# Pre-deployed HelloWormhole contract addresses (off-chain quotes version)
# Deploy these using forge script or manually, then add addresses here
HELLO_WORMHOLE_SEPOLIA=0x8f6E15d9A4d0abCe4814c7d86D5B741A91bDCC04
HELLO_WORMHOLE_BASE_SEPOLIA=0xdF781F7473a1A7C20C1e5fC5f427Fa712dafB698

# HelloWormholeOnChainQuote contract addresses (on-chain quotes version)
# Deploy using: forge script script/HelloWormholeOnChainQuote.s.sol --rpc-url $RPC_URL --broadcast --verify
HELLO_WORMHOLE_OC_SEPOLIA=0x...
HELLO_WORMHOLE_OC_BASE_SEPOLIA=0x...

# On-chain quoter address (operated by Wormhole)
QUOTER_ADDRESS=0x5241c9276698439fef2780dbab76fec90b633fbd

# ── Cross-VM (EVM → Solana) ──────────────────────────────────────────────
# HelloWormhole contract with sendGreetingWithMsgValue support
HELLO_WORMHOLE_SEPOLIA_CROSSVM=0x978d3cF51e9358C58a9538933FC3E277C29915C5

# Note: The following are automatically provided by Wormhole SDK:
# - Wormhole chain IDs (via chains.chainToChainId())
# - CoreBridge addresses (via SDK chain configs)
